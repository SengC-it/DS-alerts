# ===== DS-Alerts 环境变量 =====
# 用于 GitHub Actions (scan.yml) 和本地测试

# Supabase (必填)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...            # service_role key, 用于写入信号和数据

# 邮件发送 (Brevo 优先, Gmail 备选)
BREVO_API_KEY=your-brevo-api-key       # 推荐: Brevo 免费300封/天, REST API最简单
GMAIL_USER=your-email@gmail.com        # 备选: Gmail SMTP
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx # Gmail 应用专用密码

# 信号接收邮箱
ALERT_EMAIL=sheng.chi@qq.com

# ===== GitHub Secrets 配置清单 =====
# 在 GitHub 仓库 → Settings → Secrets and variables → Actions 中添加:
# - SUPABASE_URL
# - SUPABASE_SERVICE_KEY
# - SUPABASE_ANON_KEY         (用于 Pages 仪表盘读数据)
# - BREVO_API_KEY             (可选)
# - GMAIL_USER                (可选, Gmail备选)
# - GMAIL_APP_PASSWORD        (可选, Gmail备选)
# - ALERT_EMAIL

# ===== Supabase Edge Function 环境变量 =====
# 在 Supabase Dashboard → Edge Functions → Settings 中配置

# Supabase (自动注入，无需手动设置)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Gmail / Brevo (邮件发送，二选一)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
BREVO_API_KEY=your-brevo-api-key     # 可选，比Gmail更稳定

# 信号接收邮箱
ALERT_EMAIL=sheng.chi@qq.com

# 安全：pg_cron 调用时携带的密钥
CRON_SECRET=your-random-secret

# ===== GitHub Secrets (用于 Pages 仪表盘) =====
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
